%----------------------------------------------------------------
% Numérotation des sections : réinitialisée à chaque chapitre
% Format Section.Sous-section.Sous-sous-section (sans le numéro de chapitre)
%----------------------------------------------------------------
\usepackage{chngcntr}
\counterwithin{section}{chapter}            % Réinitialise la section à chaque nouveau chapitre
\renewcommand{\thesection}{\Roman{section}} % Section en chiffres romains (I, II, III...)
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}      % I.1, I.2...
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}} % I.1.1...

%----------------------------------------------------------------
% Titres de chapitres et sections
%----------------------------------------------------------------
\usepackage{titlesec}
\usepackage{titletoc}

% Chapitres numérotés : sans saut de page après le titre
\titleformat{\chapter}[display]
{\vspace{3.5cm}\centering\normalfont}
{\rule{3cm}{2.5pt}\quad\fontsize{20}{24}\bfseries\MakeUppercase{\chaptertitlename}~\thechapter\quad\rule{3cm}{2.5pt}}{20pt}
{\fontsize{18}{22}\bfseries\MakeUppercase}
[\vspace{2.5cm}]  % pas de \clearpage

% Chapitres non numérotés : sans saut de page après
\titleformat{name=\chapter,numberless}[display]
{\vspace{3.5cm}\centering\normalfont}
{}{0pt}
{\fontsize{22}{26}\bfseries\MakeUppercase}
[\vspace{2.5cm}]  % pas de \clearpage

\titlespacing*{\chapter}{0pt}{0pt}{0pt}
\titlespacing*{name=\chapter,numberless}{0pt}{0pt}{0pt}

% Section : majuscule, taille 18
\titleformat{\section}
{\normalfont\fontsize{18}{22}\bfseries\MakeUppercase}
{\thesection}{0.8em}{}
\titlespacing*{\section}{0pt}{20pt plus 8pt minus 6pt}{10pt plus 4pt minus 3pt}

% Sous-section : minuscule, taille 16, gras
\titleformat{\subsection}
{\normalfont\fontsize{16}{20}\bfseries}
{\thesubsection}{0.8em}{}
\titlespacing*{\subsection}{0pt}{14pt plus 6pt minus 5pt}{6pt plus 3pt minus 3pt}

% Sous-sous-section : taille 14, gras
\titleformat{\subsubsection}
{\normalfont\fontsize{14}{17}\bfseries}
{\thesubsubsection}{0.6em}{}
\titlespacing*{\subsubsection}{0pt}{10pt plus 4pt minus 2pt}{4pt plus 2pt minus 2pt}

\renewcommand{\theparagraph}{\alph{paragraph})}
\setcounter{secnumdepth}{4}

\titleformat{\paragraph}[hang]{\normalfont\normalsize\bfseries}{\theparagraph}{0.6em}{}
\titlespacing*{\paragraph}{0pt}{8pt plus 4pt minus 2pt}{4pt plus 2pt minus 2pt}

